{
  "manifest_version": 3,
  "name": "Q Check",
  "version": "1.0.0",
  "description": "Run PSC Port State Control quality checks on IMO numbers directly from your browser.",

  "action": {
    "default_icon": {
      "16":  "assets/icon-16.png",
      "32":  "assets/icon-32.png",
      "128": "assets/icon-128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "assets/icon-16.png",
    "32":  "assets/icon-32.png",
    "128": "assets/icon-128.png"
  },

  "permissions": [
    "storage",
    "tabs",
    "sidePanel"
  ],

  "side_panel": {
    "default_path": "popup.html"
  },

  "host_permissions": [
    "https://pscplatformalpha.onrender.com/*",
    "https://zammad-dashboard.onrender.com/*"
  ]
}
