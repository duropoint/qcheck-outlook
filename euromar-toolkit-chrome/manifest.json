{
  "manifest_version": 3,
  "name": "EUROMAR Toolkit",
  "version": "1.0.1",
  "description": "Collection of internal EUROMAR tools — loads UI from the EUROMAR Toolkit hosted backend.",
  "permissions": [
    "contextMenus",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://duropoint.github.io/*",
    "https://pscplatformalpha.onrender.com/*",
    "https://euromar.zammad.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://euromar.zammad.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "EUROMAR Toolkit"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
